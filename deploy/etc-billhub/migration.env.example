# =============================================================================
# migration.env — окружение one-shot сервиса migrate (DDL-роль, C5).
# Копируется в /etc/billhub/migration.env на VPS, права 640 root:docker.
#
# Изолирован от runtime.env: DDL-креды доступны ТОЛЬКО контейнеру migrate, не API/worker.
# migrate-CLI читает DATABASE_MIGRATION_URL (фоллбэк DATABASE_URL). assertNotSupabase блокирует
# применение к Supabase-хосту. MIGRATIONS_DIR уже задан в образе (/app/sql/migrations).
# =============================================================================

NODE_ENV=production

# Пользователь миграций (DDL, conn_limit=5):
DATABASE_MIGRATION_URL=postgresql://billhub_migration:CHANGE_ME@<pg-host>:6432/billhub_db?sslmode=verify-full

# CA для verify-full (psql/migrate runner):
DATABASE_SSL_CA_PATH=/etc/yandex-pg/ca.crt
PGSSLROOTCERT=/etc/yandex-pg/ca.crt
