# =============================================================================
# runtime.env — окружение billhub-api + billhub-worker (DML-роль, C5).
# Копируется в /etc/billhub/runtime.env на VPS, права 640 root:docker, значения CHANGE_ME заменить.
#
# ВАЖНО (C5): здесь НЕТ DATABASE_MIGRATION_URL — DDL-креды только в migration.env (сервис migrate).
# Имена переменных сверены с server/src/config.ts. НЕ коммитить заполненный файл.
# =============================================================================

# ---------- Режим ----------
NODE_ENV=production
PORT=3000
# Same-origin (C6): один домен. CORS_ORIGIN = origin фронта (он же origin API).
CORS_ORIGIN=https://billhub.example

# ---------- Провайдер БД (startup-инвариант в production) ----------
DB_PROVIDER=drizzle

# ---------- Yandex Managed PostgreSQL — РАНТАЙМ-пользователь (DML, conn_limit=30) ----------
DATABASE_URL=postgresql://billhub_runtime:CHANGE_ME@<pg-host>:6432/billhub_db?sslmode=verify-full
DATABASE_POOL_MAX=10
DATABASE_SSL_CA_PATH=/etc/yandex-pg/ca.crt
PGSSLROOTCERT=/etc/yandex-pg/ca.crt
DATABASE_RUNTIME_USER=billhub_runtime
DATABASE_CONN_LIMIT=30

# ---------- Аутентификация (standalone, стандарт §13) ----------
AUTH_MODE=standalone
AUTH_JWT_SECRET=CHANGE_ME
JWT_ISSUER=BillHub
JWT_AUDIENCE=billhub
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TTL_SECONDS=2592000
REFRESH_GRACE_MS=5000
CSRF_SECRET=CHANGE_ME
AUDIT_HMAC_KEY=CHANGE_ME

# ---------- Хранилище файлов (Cloud.ru S3) ----------
STORAGE_PROVIDER=cloudru
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-msk
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=billhub-s3

# ---------- OpenRouter (OCR) ----------
OPENROUTER_API_KEY=CHANGE_ME

# ---------- Интеграция EstiMat <-> BillHub (путь 1, заявки на оплату по РП) ----------
# Опционально. Авторизация — Api-Key (НЕ Bearer), два независимых секрета по направлениям.
# Входящий: токен, которым EstiMat вызывает BillHub /api/external/v1 (BillHub его ПРОВЕРЯЕТ).
#   = BILLHUB_API_TOKEN на стороне EstiMat. Пусто = входящий сервисный API выключен (401).
ESTIMAT_INBOUND_TOKEN=
# Исходящий канал событий BillHub -> EstiMat (/api/integration/events): адрес EstiMat + токен.
#   ESTIMAT_INTEGRATION_TOKEN = INTEGRATION_API_KEY на стороне EstiMat.
ESTIMAT_BASE_URL=https://estimat.su10.ru
ESTIMAT_INTEGRATION_TOKEN=
# ESTIMAT_TIMEOUT_MS=15000
# Рубильник отправки событий. Держать false, пока приёмная сторона не готова и не проверена на стенде.
ESTIMAT_SYNC_ENABLED=false

# ---------- Тендерный портал (путь 2) — опционально ----------
# Авторизация — Bearer. Портал строится в отдельном проекте; пусто = интеграция не настроена.
TENDER_BASE_URL=
TENDER_API_TOKEN=
# TENDER_TIMEOUT_MS=15000

# ---------- Redis (приватная сеть портала, сервис redis) ----------
REDIS_URL=redis://redis:6379

# ---------- Воркеры (RUN_WORKERS задаётся per-container в compose) ----------
OCR_CONCURRENCY=3
FILE_PROCESSING_CONCURRENCY=3

# ---------- Загрузка файлов ----------
MAX_FILE_SIZE_MB=100

# ---------- Mail-stub (C9): защищённый файл в volume mail-stub, НЕ stdout ----------
MAIL_STUB_LOG_PATH=/app/data/mail-stub.log

# ---------- Supabase (принцип 2: требуется config.ts при старте; для rollback-скриптов) ----------
# Реальные значения (если старый проект жив) или любой непустой non-placeholder.
# НИКОГДА не подавать в migrate runner (assertNotSupabase блокирует).
SUPABASE_URL=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
SUPABASE_JWT_SECRET=CHANGE_ME

# ---------- Observability ----------
# LOG_LEVEL=info
# Sentry (§11) — задел, пока не подключён (ADR-0007). Оставить пустым:
SENTRY_DSN=
