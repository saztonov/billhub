# ==========================================
# Фронтенд BillHub — переменные окружения
# ==========================================
# Скопируйте в .env: cp .env.example .env
#
# После миграции на клиент-серверную архитектуру
# все секреты (S3, Supabase, OpenRouter) хранятся
# ТОЛЬКО на сервере (server/.env).
# Фронтенд не содержит секретных ключей.
# ==========================================

# URL бэкенда (опционально)
# В dev-режиме Vite проксирует /api/* на http://localhost:3000
# В production nginx проксирует /api/* на backend:3000
# Указывать только если бэкенд на другом домене/порте
# VITE_API_URL=

# Максимальный размер загружаемого файла в МБ (клиентская валидация)
VITE_MAX_FILE_SIZE_MB=100
