# ===== DEPRECATED / LEGACY — НЕ использовать для VPS2 (Этап 1) =====
# Канонический шаблон окружения — deploy/etc-billhub/runtime.env.example + migration.env.example
# (корпстандарт v3.1, ADR-0007): раздельные runtime/migration креды. Этот файл сохранён как
# справочный; здесь runtime и DDL-креды смешаны в одном .env — на VPS2 не использовать.
# ==================================================================
# =============================================================================
# .env.production.example — шаблон ПРЕЖНЕГО all-in-one стека (справочный, не для VPS2).
#
# Копируется в ./server/.env на целевой VPS, заполняется реальными значениями, права 600.
# ВСЕ значения CHANGE_ME заменить ПЕРЕД стартом — production startup checks валят сервис
# при placeholder ('change_me', 'your-', 'dev-insecure', 'localhost', ...).
#
# НЕ коммитить заполненный .env! Имена переменных сверены с server/src/config.ts.
# =============================================================================

# ---------- Режим ----------
NODE_ENV=production
PORT=3000
# Точный origin фронтенда (TLS). Не указывать localhost в production.
CORS_ORIGIN=https://billhub.example-domain.ru

# ---------- Провайдер БД (startup-инвариант в production) ----------
DB_PROVIDER=drizzle

# ---------- Yandex Managed PostgreSQL (через PgBouncer :6432, TLS verify-full) ----------
# Рантайм-пользователь (DML, conn_limit=30):
DATABASE_URL=postgresql://billhub_runtime:CHANGE_ME@<pg-host>:6432/billhub_db?sslmode=verify-full
# Пользователь миграций (DDL, conn_limit=5) — для bootstrap-schema.sh и migrate.js:
DATABASE_MIGRATION_URL=postgresql://billhub_migration:CHANGE_ME@<pg-host>:6432/billhub_db?sslmode=verify-full
# Размер пула postgres.js на процесс (connection budget ADR-0005):
DATABASE_POOL_MAX=10
# Yandex CA для verify-full (см. yandex-pg-setup.md §3):
DATABASE_SSL_CA_PATH=/etc/yandex-pg/ca.crt
# Тот же CA для psql/migrate runner:
PGSSLROOTCERT=/etc/yandex-pg/ca.crt
# Мониторинг соединений (Iteration 7): пользователь runtime и его conn_limit (порог алерта).
DATABASE_RUNTIME_USER=billhub_runtime
DATABASE_CONN_LIMIT=30

# ---------- Аутентификация (standalone, стандарт v3 §13) ----------
AUTH_MODE=standalone
# Секрет подписи access JWT (HS256), >= 32 случайных байт:
AUTH_JWT_SECRET=CHANGE_ME
JWT_ISSUER=BillHub
JWT_AUDIENCE=billhub
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TTL_SECONDS=2592000
# Grace-window ротации refresh (мс) — параллельные вкладки:
REFRESH_GRACE_MS=5000
# Double-submit CSRF cookie:
CSRF_SECRET=CHANGE_ME
# HMAC-ключ псевдонимизации email в audit_log и ключах rate-limit:
AUDIT_HMAC_KEY=CHANGE_ME

# ---------- Хранилище файлов (Cloud.ru S3) ----------
STORAGE_PROVIDER=cloudru
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-msk
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=billhub-s3

# ---------- OpenRouter (OCR) ----------
OPENROUTER_API_KEY=CHANGE_ME

# ---------- Redis (BullMQ + chunked-upload sessions) ----------
REDIS_URL=redis://redis:6379

# ---------- Воркеры (Iteration 8 — разделение API/worker) ----------
# RUN_WORKERS задаётся per-container в docker-compose.production.yml:
#   backend → RUN_WORKERS=false (только enqueue), worker → RUN_WORKERS=true.
# Здесь — значения по умолчанию для worker-контейнера:
OCR_CONCURRENCY=3
FILE_PROCESSING_CONCURRENCY=3

# ---------- Загрузка файлов ----------
MAX_FILE_SIZE_MB=100

# ---------- Supabase (принцип 2: остаётся для rollback/миграционных скриптов) ----------
# Требуется config.ts при старте (validateRequired). В Этапе 1 на новой инфре рантайм-путь —
# Drizzle; эти значения нужны только явным диагностическим/rollback-скриптам.
# Если старый Supabase-проект ещё жив (fallback ≥30 дней) — реальные значения; иначе любой
# непустой non-placeholder. НИКОГДА не подавать их в migrate runner (assertNotSupabase блокирует).
SUPABASE_URL=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
SUPABASE_JWT_SECRET=CHANGE_ME

# ---------- Observability (Iteration 7) ----------
# LOG_LEVEL=info
# MAIL_STUB_LOG_PATH=./data/mail-stub.log
