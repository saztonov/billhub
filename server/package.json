{
  "name": "billhub-server",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "chcp 65001 >nul && tsx watch src/server.ts",
    "build": "tsc",
    "start": "chcp 65001 >nul && node --max-old-space-size=512 dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:migrate:built": "node dist/cli/migrate.js",
    "drizzle:introspect": "drizzle-kit introspect"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.1",
    "@supabase/supabase-js": "^2.95.3",
    "bullmq": "^5.34.8",
    "canvas": "^3.2.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.6.0",
    "jose": "^6.0.11",
    "lru-cache": "^11.1.0",
    "pdfjs-dist": "^4.10.38",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "vitest": "^4.1.7"
  }
}
