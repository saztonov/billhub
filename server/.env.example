# ==========================================
# Бэкенд BillHub (Fastify) — переменные окружения
# ==========================================
# Скопируйте в .env и задайте права:
#   cp .env.example .env
#   chmod 600 .env
# НИКОГДА не коммитьте .env в git!
# ==========================================

# ---------- Fastify ----------
PORT=3000
# Разрешенный origin для CORS (адрес фронтенда)
# Dev: http://localhost:5173 | Production: https://your-domain.ru
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# ---------- Supabase ----------
# Dashboard -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
# Dashboard -> Settings -> API -> service_role key (секретный, НЕ anon)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Dashboard -> Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ---------- Провайдер БД (Strangler Fig: Supabase ↔ Drizzle) ----------
# supabase (по умолчанию) — рантайм через @supabase/supabase-js (PostgREST).
# drizzle — рантайм через Drizzle ORM + postgres.js (требует DATABASE_URL).
# В production обязателен DB_PROVIDER=drizzle (startup-инвариант включается с Iteration 5).
DB_PROVIDER=supabase

# Yandex Managed PostgreSQL / локальный Postgres (нужны только при DB_PROVIDER=drizzle).
# Рантайм-пользователь (DML):
# DATABASE_URL=postgresql://billhub_runtime:secret@host:6432/billhub_db?sslmode=verify-full
# Пользователь миграций (DDL) для db:migrate (по умолчанию = DATABASE_URL):
# DATABASE_MIGRATION_URL=postgresql://billhub_migration:secret@host:6432/billhub_db?sslmode=verify-full
# Размер пула postgres.js (по умолчанию 10):
# DATABASE_POOL_MAX=10
# Пользователь runtime для мониторинга соединений (Iteration 7, по умолчанию billhub_runtime):
# DATABASE_RUNTIME_USER=billhub_runtime
# conn_limit пользователя runtime — порог алерта DB connections (ADR-0005 = 30):
# DATABASE_CONN_LIMIT=30
# Аварийный override запрета миграций к Supabase-хосту (assertNotSupabase). НЕ задавать в норме!
# ALLOW_SUPABASE_MIGRATIONS=1

# ---------- Аутентификация (Iteration 6, стандарт v3 раздел 13) ----------
# Режим: supabase-bridge (legacy, Supabase Auth) | standalone (собственный стек).
# Это ОБЫЧНЫЙ feature-флаг, НЕ startup-инвариант (в отличие от DB_PROVIDER).
AUTH_MODE=supabase-bridge
# Секрет подписи access JWT (HS256) в standalone-режиме. В production — из защищённого
# хранилища (.env с правами 600 в Этапе 1, Lockbox в Этапе 2). Длина >= 32 байт.
AUTH_JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=BillHub
JWT_AUDIENCE=billhub
# Время жизни access-токена (сек, 15 мин) и refresh-токена (сек, 30 дней).
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TTL_SECONDS=2592000
# Grace-window ротации refresh (мс): параллельные вкладки получают тот же новый токен.
REFRESH_GRACE_MS=5000
# Double-submit CSRF cookie.
CSRF_SECRET=change-me-to-a-long-random-secret
# HMAC-ключ псевдонимизации email в audit_log и ключах rate-limit.
AUDIT_HMAC_KEY=change-me-to-a-long-random-secret

# ---------- S3-хранилище ----------
# Провайдер: cloudru | cloudflare
STORAGE_PROVIDER=cloudru

# Cloud.ru S3
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-msk
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=your-bucket

# Cloudflare R2 (альтернативный провайдер)
# STORAGE_PROVIDER=cloudflare
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your-r2-access-key
# R2_SECRET_KEY=your-r2-secret-key
# R2_BUCKET=your-r2-bucket

# ---------- OpenRouter (OCR) ----------
OPENROUTER_API_KEY=your-openrouter-key

# ---------- Redis (BullMQ) ----------
# Docker: redis://redis:6379 | Локально: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ---------- Загрузка файлов ----------
MAX_FILE_SIZE_MB=100

# ---------- Observability (Iteration 7) ----------
# Уровень логирования pino (по умолчанию info в production, debug иначе).
# LOG_LEVEL=info
# Путь NDJSON-лога заглушки @su10/mail (по умолчанию server/data/mail-stub.log).
# MAIL_STUB_LOG_PATH=./data/mail-stub.log
