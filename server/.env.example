# ==========================================
# Бэкенд BillHub (Fastify) — переменные окружения
# ==========================================
# Скопируйте в .env и задайте права:
#   cp .env.example .env
#   chmod 600 .env
# НИКОГДА не коммитьте .env в git!
# ==========================================

# ---------- Fastify ----------
PORT=3000
# Разрешенный origin для CORS (адрес фронтенда)
# Dev: http://localhost:5173 | Production: https://your-domain.ru
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# ---------- Supabase ----------
# Dashboard -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
# Dashboard -> Settings -> API -> service_role key (секретный, НЕ anon)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Dashboard -> Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ---------- S3-хранилище ----------
# Провайдер: cloudru | cloudflare
STORAGE_PROVIDER=cloudru

# Cloud.ru S3
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-msk
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=your-bucket

# Cloudflare R2 (альтернативный провайдер)
# STORAGE_PROVIDER=cloudflare
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your-r2-access-key
# R2_SECRET_KEY=your-r2-secret-key
# R2_BUCKET=your-r2-bucket

# ---------- OpenRouter (OCR) ----------
OPENROUTER_API_KEY=your-openrouter-key

# ---------- Redis (BullMQ) ----------
# Docker: redis://redis:6379 | Локально: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ---------- Загрузка файлов ----------
MAX_FILE_SIZE_MB=100
